import pygame
import sys
import math

# Pygame Başlat
pygame.init()

# Ekran Ayarları
GENISLIK, YUKSEKLIK = 800, 600
ekran = pygame.display.set_mode((GENISLIK, YUKSEKLIK))
pygame.display.set_caption("EFIS - B737 MAX 8 PFD (GPWS Terrain Pull Up Sistemi)")

# Renkler
GOKYUZU_MAVISI = (30, 144, 255)
TOPRAK_KAHVESI = (139, 69, 19)
BEYAZ = (255, 255, 255)
SARI = (255, 255, 0)
YESIL = (0, 255, 0)
SIYAH = (0, 0, 0)
GRI = (40, 40, 40)
KIRMIZI = (255, 0, 0)
TURUNCU = (255, 140, 0) # GPWS Çarpısı için yeni renk

# Uçuş Verileri
sanal_pitch = 0.0      
sanal_roll = 0.0       
speed = 250.0    
altitude = 10000.0 
heading = 360.0  

# Limitler (B737 MAX 8 Referansları)
V_STALL = 120.0
V_MAX = 340.0
BANK_LIMIT = 33.0 

# İvme ve Dinamik Kuvvetler
pitch_hizi = 0.0
roll_hizi = 0.0
g_force_display = 1.0 

# Fontlar
font_kucuk = pygame.font.SysFont("Arial", 14, bold=True)
font_orta = pygame.font.SysFont("Arial", 18, bold=True)
font_buyuk = pygame.font.SysFont("Arial", 28, bold=True) # Uyarılar için biraz daha büyüttüm
font_g = pygame.font.SysFont("Arial", 28, bold=True)

saat = pygame.time.Clock()

def dikey_bant_ciz(yuzey, x, y, genislik, yukseklik, deger, adim, olcek, birim_etiketi, renk_kodu, limit_alt=None, limit_ust=None):
    pygame.draw.rect(yuzey, GRI, (x, y, genislik, yukseklik))
    pygame.draw.rect(yuzey, BEYAZ, (x, y, genislik, yukseklik), 2)
    merkez_y = y + yukseklik // 2
    baslangic = int(deger - (yukseklik / olcek / 2))
    bitis = int(deger + (yukseklik / olcek / 2))
    
    if limit_ust is not None:
        ust_y = int(merkez_y + (deger - limit_ust) * olcek)
        if ust_y > y: 
            cizim_h = min(ust_y - y, yukseklik)
            pygame.draw.rect(yuzey, KIRMIZI, (x + genislik - 8, y, 8, cizim_h))
            
    if limit_alt is not None:
        alt_y = int(merkez_y + (deger - limit_alt) * olcek)
        if alt_y < y + yukseklik:
            cizim_y = max(y, alt_y)
            cizim_h = (y + yukseklik) - cizim_y
            pygame.draw.rect(yuzey, KIRMIZI, (x + genislik - 8, cizim_y, 8, cizim_h))

    for v in range(baslangic - adim, bitis + adim):
        if v % adim == 0:
            dy = (deger - v) * olcek
            cizgi_y = int(merkez_y + dy)
            if y < cizgi_y < y + yukseklik:
                pygame.draw.line(yuzey, BEYAZ, (x, cizgi_y), (x + 15, cizgi_y), 2)
                metin = font_orta.render(str(v), True, BEYAZ)
                yuzey.blit(metin, (x + 25, cizgi_y - 10))
                
    kutu_y = int(merkez_y - 18)
    pygame.draw.rect(yuzey, SIYAH, (x - 5, kutu_y, genislik + 10, 36))
    
    aktif_renk = renk_kodu
    if (limit_ust is not None and deger >= limit_ust) or (limit_alt is not None and deger <= limit_alt):
        aktif_renk = KIRMIZI 
        
    pygame.draw.rect(yuzey, aktif_renk, (x - 5, kutu_y, genislik + 10, 36), 2)
    deger_metni = font_buyuk.render(f"{int(deger)}", True, aktif_renk)
    yuzey.blit(deger_metni, (x + 15, kutu_y + 4))
    
    etiket = font_kucuk.render(birim_etiketi, True, BEYAZ)
    yuzey.blit(etiket, (x + genislik//2 - 15, y - 20))

def yatay_pusula_ciz(yuzey, x, y, genislik, yukseklik, deger):
    pygame.draw.rect(yuzey, GRI, (x, y, genislik, yukseklik))
    pygame.draw.rect(yuzey, BEYAZ, (x, y, genislik, yukseklik), 2)
    merkez_x = x + genislik // 2
    baslangic = int(deger - (genislik / 4 / 2))
    bitis = int(deger + (genislik / 4 / 2))
    
    for v in range(baslangic - 10, bitis + 10):
        if v % 10 == 0:
            dx = (v - deger) * 4
            cizgi_x = int(merkez_x + dx)
            gosterim_v = v % 360
            if gosterim_v == 0: gosterim_v = 360
            
            if x < cizgi_x < x + genislik:
                pygame.draw.line(yuzey, BEYAZ, (cizgi_x, y), (cizgi_x, y + 10), 2)
                if v % 30 == 0:
                    metin = font_kucuk.render(str(gosterim_v), True, BEYAZ)
                    yuzey.blit(metin, (cizgi_x - 10, y + 15))
                    
    pygame.draw.polygon(yuzey, SARI, [(merkez_x, y), (merkez_x - 10, y - 10), (merkez_x + 10, y - 10)])

def ana_dongu():
    global sanal_pitch, sanal_roll, speed, altitude, heading, pitch_hizi, roll_hizi, g_force_display
    calisiyor = True

    while calisiyor:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                calisiyor = False

        tuslar = pygame.key.get_pressed()
        
        # PITCH 
        if tuslar[pygame.K_UP]: pitch_hizi += 0.05
        elif tuslar[pygame.K_DOWN]: pitch_hizi -= 0.05
        else: pitch_hizi *= 0.96 
        pitch_hizi = max(-2.5, min(2.5, pitch_hizi))
        sanal_pitch += pitch_hizi

        # ROLL 
        if tuslar[pygame.K_LEFT]: roll_hizi -= 0.12 
        elif tuslar[pygame.K_RIGHT]: roll_hizi += 0.12 
        else: roll_hizi *= 0.95 
        roll_hizi = max(-3.0, min(3.0, roll_hizi))
        sanal_roll += roll_hizi
        
        # HIZ KONTROLLERİ 
        if tuslar[pygame.K_w]: speed += 1.5
        if tuslar[pygame.K_s]: speed -= 1.5
        if tuslar[pygame.K_d]: heading += 1.0
        if tuslar[pygame.K_a]: heading -= 1.0

        # G-KUVVETİ 
        speed_ms = speed * 0.514444
        pitch_rate_rads = math.radians(pitch_hizi * 60)
        g_statik = math.cos(math.radians(sanal_pitch)) * math.cos(math.radians(sanal_roll))
        g_merkezkac = (speed_ms * pitch_rate_rads) / 9.81
        hedef_g = g_statik + g_merkezkac
        g_force_display += (hedef_g - g_force_display) * 0.1

        # TRIGONOMETRİK İRTİFA VE VARYOMETRE
        v_s_fpm = speed * 101.268 * math.sin(math.radians(sanal_pitch))
        altitude += v_s_fpm / 3600.0

        # LİMİTLER
        sanal_pitch = (sanal_pitch + 180) % 360 - 180
        sanal_roll = (sanal_roll + 180) % 360 - 180
        speed = max(0.0, min(500.0, speed)) 
        altitude = max(0.0, altitude) 
        heading = heading % 360
        if heading == 0: heading = 360

        # --- GPWS (TERRAIN PULL UP) MANTIĞI ---
        # İrtifa 2500 feet'in altındaysa ve alçalma hızı -1500 ft/min'den fazlaysa GPWS tetiklenir!
        gpws_aktif = False
        if altitude < 2500.0 and v_s_fpm <= -1500.0:
            gpws_aktif = True

        # GIMBAL FLIP 
        if sanal_pitch > 90:
            gosterim_pitch = 180 - sanal_pitch
            gosterim_roll = sanal_roll + 180
        elif sanal_pitch < -90:
            gosterim_pitch = -180 - sanal_pitch
            gosterim_roll = sanal_roll + 180
        else:
            gosterim_pitch = sanal_pitch
            gosterim_roll = sanal_roll

        ekran.fill(SIYAH)

        # SUNİ UFUK
        ufuk_merkezi_x, ufuk_merkezi_y = GENISLIK // 2, YUKSEKLIK // 2
        zemin_boyutu = 1600 
        
        kamera = pygame.Surface((zemin_boyutu, zemin_boyutu), pygame.SRCALPHA)
        kamera.fill(SIYAH)
        
        ufuk_y_koordinati = int((zemin_boyutu // 2) + (gosterim_pitch * 8))
        
        pygame.draw.rect(kamera, GOKYUZU_MAVISI, (0, 0, zemin_boyutu, ufuk_y_koordinati))
        pygame.draw.rect(kamera, TOPRAK_KAHVESI, (0, ufuk_y_koordinati, zemin_boyutu, zemin_boyutu - ufuk_y_koordinati))
        pygame.draw.line(kamera, BEYAZ, (0, ufuk_y_koordinati), (zemin_boyutu, ufuk_y_koordinati), 4)

        for p in range(-90, 91, 10):
            if p == 0: continue
            y_cizgi = int(ufuk_y_koordinati - (p * 8))
            
            if 0 < y_cizgi < zemin_boyutu:
                gen = 120 if p > 0 else 60
                pygame.draw.line(kamera, BEYAZ, (zemin_boyutu // 2 - gen // 2, y_cizgi), 
                                 (zemin_boyutu // 2 + gen // 2, y_cizgi), 3)
                p_metin = font_kucuk.render(str(abs(p)), True, BEYAZ)
                kamera.blit(p_metin, (zemin_boyutu // 2 + gen // 2 + 10, y_cizgi - 8))
                kamera.blit(p_metin, (zemin_boyutu // 2 - gen // 2 - 25, y_cizgi - 8))

        dondurulmus = pygame.transform.rotate(kamera, gosterim_roll)
        dikdortgen = dondurulmus.get_rect(center=(ufuk_merkezi_x, ufuk_merkezi_y))
        ekran.blit(dondurulmus, dikdortgen.topleft)

        # Maskeleme
        pygame.draw.rect(ekran, SIYAH, (0, 0, 200, YUKSEKLIK)) 
        pygame.draw.rect(ekran, SIYAH, (GENISLIK - 200, 0, 200, YUKSEKLIK)) 
        pygame.draw.rect(ekran, SIYAH, (0, 0, GENISLIK, 100)) 
        pygame.draw.rect(ekran, SIYAH, (0, YUKSEKLIK - 100, GENISLIK, 100)) 

        # Sabit Uçak İkonu
        pygame.draw.line(ekran, SARI, (ufuk_merkezi_x - 70, ufuk_merkezi_y), (ufuk_merkezi_x - 20, ufuk_merkezi_y), 5)
        pygame.draw.line(ekran, SARI, (ufuk_merkezi_x - 20, ufuk_merkezi_y), (ufuk_merkezi_x - 20, ufuk_merkezi_y + 20), 5)
        pygame.draw.line(ekran, SARI, (ufuk_merkezi_x + 20, ufuk_merkezi_y), (ufuk_merkezi_x + 70, ufuk_merkezi_y), 5)
        pygame.draw.line(ekran, SARI, (ufuk_merkezi_x + 20, ufuk_merkezi_y), (ufuk_merkezi_x + 20, ufuk_merkezi_y + 20), 5)
        pygame.draw.rect(ekran, KIRMIZI, (ufuk_merkezi_x - 5, ufuk_merkezi_y - 5, 10, 10))

        # --- GÖSTERGE BANTLARI ---
        dikey_bant_ciz(ekran, 80, 150, 80, 300, speed, 20, 3.0, "SPD", YESIL, limit_alt=V_STALL, limit_ust=V_MAX)
        dikey_bant_ciz(ekran, GENISLIK - 160, 150, 80, 300, altitude, 100, 0.5, "ALT", SARI)
        yatay_pusula_ciz(ekran, GENISLIK // 2 - 150, YUKSEKLIK - 80, 300, 40, heading)

        # OTOPİLOT
        mod_metni = font_orta.render("B737 MAX 8 |  AP1  |  A/THR", True, YESIL)
        ekran.blit(mod_metni, (GENISLIK // 2 - mod_metni.get_width() // 2, 40))
        
        # Zamanlayıcı (Flaşör efekti için)
        zaman = pygame.time.get_ticks()
        yanip_sonme = (zaman // 250) % 2 == 0 # 250ms (daha agresif yanıp sönme)
        
        # --- GPWS TERRAIN EKRAN ÇİZİMİ (F-16 / HUD STYLE) ---
        if gpws_aktif and yanip_sonme:
            # 1. Dev Turuncu Çarpı
            pygame.draw.line(ekran, TURUNCU, (GENISLIK//2 - 120, YUKSEKLIK//2 - 120), (GENISLIK//2 + 120, YUKSEKLIK//2 + 120), 12)
            pygame.draw.line(ekran, TURUNCU, (GENISLIK//2 + 120, YUKSEKLIK//2 - 120), (GENISLIK//2 - 120, YUKSEKLIK//2 + 120), 12)
            
            # 2. Devasa Kırmızı Yukarı Ok
            ok_x = GENISLIK // 2
            ok_y = YUKSEKLIK // 2 - 20
            pygame.draw.polygon(ekran, KIRMIZI, [(ok_x, ok_y - 90), (ok_x - 45, ok_y - 30), (ok_x + 45, ok_y - 30)]) # Ok başı
            pygame.draw.rect(ekran, KIRMIZI, (ok_x - 20, ok_y - 30, 40, 70)) # Ok gövdesi
            
            # 3. Metinler ("TERRAIN TERRAIN" ve "PULL UP")
            terr_metin = font_buyuk.render("TERRAIN TERRAIN", True, TURUNCU)
            pull_metin = font_buyuk.render("PULL UP", True, KIRMIZI)
            
            # Yazıların arkasına siyah gölge (okunabilirliği artırmak için)
            pygame.draw.rect(ekran, SIYAH, (GENISLIK // 2 - terr_metin.get_width()//2 - 10, YUKSEKLIK // 2 - 165, terr_metin.get_width() + 20, 35))
            pygame.draw.rect(ekran, SIYAH, (GENISLIK // 2 - pull_metin.get_width()//2 - 10, YUKSEKLIK // 2 + 35, pull_metin.get_width() + 20, 35))

            ekran.blit(terr_metin, (GENISLIK // 2 - terr_metin.get_width() // 2, YUKSEKLIK // 2 - 165))
            ekran.blit(pull_metin, (GENISLIK // 2 - pull_metin.get_width() // 2, YUKSEKLIK // 2 + 35))


        # --- DİĞER UYARI SİSTEMLERİ (EICAS) ---
        uyari_yazisi = None
        if speed >= V_MAX: uyari_yazisi = "OVERSPEED"
        elif speed <= V_STALL: uyari_yazisi = "STALL"
            
        if uyari_yazisi and yanip_sonme:
            w_metin = font_buyuk.render(uyari_yazisi, True, KIRMIZI)
            w_genislik = w_metin.get_width() + 40
            w_x = GENISLIK // 2 - w_genislik // 2
            pygame.draw.rect(ekran, SIYAH, (w_x, 90, w_genislik, 40))
            pygame.draw.rect(ekran, KIRMIZI, (w_x, 90, w_genislik, 40), 3)
            ekran.blit(w_metin, (w_x + 20, 94))

        if abs(sanal_roll) >= BANK_LIMIT and yanip_sonme:
            b_metin = font_buyuk.render("BANK ANGLE", True, SARI)
            b_genislik = b_metin.get_width() + 40
            b_x = GENISLIK // 2 - b_genislik // 2
            pygame.draw.rect(ekran, SIYAH, (b_x, 140, b_genislik, 40))
            pygame.draw.rect(ekran, SARI, (b_x, 140, b_genislik, 40), 3)
            ekran.blit(b_metin, (b_x + 20, 144))

        # V/M KUTUSU
        vs_renk = YESIL if v_s_fpm >= 0 else KIRMIZI
        vs_isaret = "+" if v_s_fpm >= 0 else ""
        pygame.draw.rect(ekran, SIYAH, (GENISLIK - 160, 90, 80, 30))
        pygame.draw.rect(ekran, BEYAZ, (GENISLIK - 160, 90, 80, 30), 2)
        ekran.blit(font_kucuk.render("V/M", True, BEYAZ), (GENISLIK - 155, 70))
        ekran.blit(font_orta.render(f"{vs_isaret}{int(v_s_fpm)}", True, vs_renk), (GENISLIK - 150, 95))

        # G-METRE 
        g_x, g_y = 75, 470
        g_renk = YESIL
        if g_force_display >= 2.5 or g_force_display <= -1.0: g_renk = KIRMIZI 
        elif g_force_display >= 2.0 or g_force_display <= 0.0: g_renk = SARI    
            
        pygame.draw.rect(ekran, SIYAH, (g_x, g_y, 90, 35))
        pygame.draw.rect(ekran, BEYAZ, (g_x, g_y, 90, 35), 2)
        ekran.blit(font_kucuk.render("G", True, BEYAZ), (g_x + 8, g_y + 8))
        ekran.blit(font_g.render(f"{g_force_display:.1f}", True, g_renk), (g_x + 30, g_y + 2))

        pygame.display.flip()
        saat.tick(60)

    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    ana_dongu()

